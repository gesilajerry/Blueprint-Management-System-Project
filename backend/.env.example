# 应用配置
APP_NAME="图纸管理系统 API"
APP_VERSION="1.0.0"
DEBUG=True

# 服务器配置
API_HOST=0.0.0.0
API_PORT=8000

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blueprint_db

# JWT 配置
SECRET_KEY=your-secret-key-change-in-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件存储配置
FILE_STORAGE_PATH=/data/drawings
MAX_FILE_SIZE=524288000

# CORS 配置
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://192.168.20.136:3000"]
